<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="travel-ticket-service"/>

  <property name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%property{appName}] [trace=%X{traceId:-none}] [%thread] %cyan(%logger{36}) - %msg%n%ex"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <charset>UTF-8</charset>
      <pattern>${CONSOLE_PATTERN}</pattern>
    </encoder>
  </appender>

  <logger name="com.codex.travel.ticket" level="INFO"/>
  <logger name="org.springframework.data.elasticsearch.client.WIRE" level="OFF"/>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
